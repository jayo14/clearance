# ─── Django / Backend ────────────────────────────────────────────────────────

# Generate a secure random key, e.g. with:
#   python scripts/generate_secret_key.py
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (e.g. myapp.onrender.com,localhost)
ALLOWED_HOSTS=*

# Full PostgreSQL connection string (used in production).
# In development, SQLite is used by default when this is not set.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Email ───────────────────────────────────────────────────────────────────

# Use console backend for development, SMTP for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=noreply@clearance.edu.ng

# ─── Frontend / CORS ─────────────────────────────────────────────────────────

# Base URL of the deployed frontend (used in email links)
FRONTEND_URL=http://localhost:3000

# ─── Frontend (Vite / React) ─────────────────────────────────────────────────

# Google Gemini API key used by the frontend AI features
GEMINI_API_KEY=your-gemini-api-key-here
